{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Automation task management framework with mutex lock, versioning, test flows, and agent skills",
  "bin": {
    "taskflow": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/templates/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.5.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}